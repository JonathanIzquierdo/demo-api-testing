,"body":{"mode":"raw","raw":"{\"customer_email\":\"{{uniqueEmail2}}\",\"items\":[{\"product_id\":\"{{nonExistentId}}\",\"quantity\":1}]}"},"url":{"raw":"{{baseUrl}}/orders","host":["{{baseUrl}}"],"path":["orders"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 404 when product not found', function () {","    pm.response.to.have.status(404);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]},{"name":"422 - invalid request body (missing items)","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"customer_email\":\"test@example.com\"}"},"url":{"raw":"{{baseUrl}}/orders","host":["{{baseUrl}}"],"path":["orders"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 422 for validation error', function () {","    pm.response.to.have.status(422);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]}]},{"name":"GET /orders/{order_id}","item":[{"name":"200 - returns order when exists","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/orders/{{createdOrderId}}","host":["{{baseUrl}}"],"path":["orders","{{createdOrderId}}"],"variable":[{"key":"order_id","value":"{{createdOrderId}}"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response has correct order fields', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('customer_email');","    pm.expect(jsonData).to.have.property('items');","    pm.expect(jsonData).to.have.property('total');","    pm.expect(jsonData).to.have.property('status');","    pm.expect(jsonData).to.have.property('created_at');","    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('createdOrderId'));","});"],"type":"text/javascript"}}]},{"name":"404 - returns not found when order does not exist","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/orders/{{nonExistentId}}","host":["{{baseUrl}}"],"path":["orders","{{nonExistentId}}"],"variable":[{"key":"order_id","value":"{{nonExistentId}}"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 404 for non-existent order', function () {","    pm.response.to.have.status(404);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]}]}]},{"name":"99. Teardown","item":[{"name":"Teardown: Delete created resources (informational)","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]}},"event":[{"listen":"test","script":{"exec":["// TODO: DELETE endpoints for cleanup not yet implemented in backend.","// Once DELETE /orders/{order_id} and DELETE /products/{product_id} are available,","// add cleanup requests here to remove createdOrderId and createdProductId.","// For now, relying on test isolation via unique SKU/email generation.","pm.test('Teardown note: cleanup would occur here', function () {","    pm.expect(true).to.be.true;","});"],"type":"text/javascript"}}]}]}],"auth":{"type":"apikey","apikey":[{"key":"key","value":"Authorization","type":"string"},{"key":"value","value":"{{authToken}}","type":"string"}]}}