                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "const rand = Math.floor(Math.random() * 10000);",
                  "const skuRaw = 'TST' + ts + rand;",
                  "const uniqueSku = skuRaw.substring(0, 20).toUpperCase();",
                  "pm.collectionVariables.set('uniqueSku', uniqueSku);",
                  "pm.collectionVariables.set('uniqueEmail', 'test-' + ts + '@example.com');",
                  "pm.collectionVariables.set('nonExistentId', '00000000-0000-0000-0000-000000000000');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Setup: unique values generated', function () {",
                  "  pm.expect(pm.collectionVariables.get('uniqueSku')).to.be.a('string').and.not.empty;",
                  "  pm.expect(pm.collectionVariables.get('uniqueEmail')).to.include('@');",
                  "});"
                ]
              }
            }
          ],
