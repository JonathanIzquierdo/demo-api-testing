              "listen": "test",
              "script": {
                "exec": [
                  "// TODO: cleanup not possible without DELETE endpoint for products and orders.",
                  "// The fixture product (id: {{createdProductId}}) and order (id: {{createdOrderId}}) remain in the backend.",
