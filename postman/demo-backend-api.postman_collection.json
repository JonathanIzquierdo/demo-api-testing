{"info":{"name":"demo-backend-api API Tests","_postman_id":"f8a2c3e4-5d6e-4a8b-9c2d-1e3f4a5b6c7d","description":"API tests for demo-backend-api. Maintained by QAEngineerAgent.","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"variable":[{"key":"baseUrl","value":"http://localhost:8000"},{"key":"authToken","value":"demo-token-123"},{"key":"productName","value":"Test Product"},{"key":"productSku","value":"TEST-SKU-001"},{"key":"productPrice","value":"99.99"},{"key":"existingProductId","value":"prod-001"},{"key":"existingOrderId","value":"order-001"},{"key":"testCustomerEmail","value":"test-customer@example.com"},{"key":"invalidCustomerEmail","value":"invalid-email"}],"item":[{"name":"GET /health","item":[{"name":"200 - returns ok status","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response has ok status', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.status).to.equal('ok');","});"],"type":"text/javascript"}}]}]},{"name":"GET /products","item":[{"name":"200 - returns products list with default pagination","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});"],"type":"text/javascript"}}]}]},{"name":"GET /orders/{order_id}","item":[{"name":"200 - returns order when exists","request":{"method":"GET","header":[{"key":"Authorization","value":"Bearer {{authToken}}","type":"text"}],"url":{"raw":"{{baseUrl}}/orders/{{existingOrderId}}","host":["{{baseUrl}}"],"path":["orders","{{existingOrderId}}"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response has required order fields', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('customer_email');","});"],"type":"text/javascript"}}]}]},{"name":"POST /orders","item":[{"name":"201 - creates order with valid data","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}","type":"text"},{"key":"Content-Type","value":"application/json","type":"text"}],"body":{"mode":"raw","raw":"{\n  \"customer_email\": \"{{testCustomerEmail}}\",\n  \"items\": [\n    {\n      \"product_id\": \"{{existingProductId}}\",\n      \"quantity\": 2,\n      \"price\": 99.99\n    }\n  ]\n}"},"url":{"raw":"{{baseUrl}}/orders","host":["{{baseUrl}}"],"path":["orders"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 201', function () {","    pm.response.to.have.status(201);","});","pm.test('Response has required order fields', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('customer_email');","    pm.expect(jsonData.customer_email).to.equal('{{testCustomerEmail}}');","    pm.expect(jsonData).to.have.property('items');","    pm.expect(jsonData.items).to.be.an('array');","});","pm.test('Response status matches expected schema', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('status');","});","pm.test('Order items contain valid data', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.items).to.have.length.greaterThan(0);","    pm.expect(jsonData.items[0]).to.have.property('product_id');","    pm.expect(jsonData.items[0]).to.have.property('quantity');","});"]}}]},{"name":"401 - returns unauthorized without auth token","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json","type":"text"}],"body":{"mode":"raw","raw":"