{"info":{"name":"demo-backend-api API Tests","_postman_id":"f8a2c3e4-5d6e-4a8b-9c2d-1e3f4a5b6c7d","description":"API tests for demo-backend-api. Maintained by QAEngineerAgent.","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"variable":[{"key":"baseUrl","value":"http://localhost:8000"},{"key":"authToken","value":"demo-token-123"},{"key":"uniqueSku","value":""},{"key":"uniqueEmail","value":""},{"key":"nonExistentId","value":""},{"key":"createdProductId","value":""},{"key":"createdProductSku","value":""},{"key":"createdOrderId","value":""},{"key":"uniqueSku2","value":""},{"key":"uniqueEmail2","value":""}],"item":[{"name":"0. Setup","item":[{"name":"Setup: Generate unique identifiers","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]}},"event":[{"listen":"prerequest","script":{"exec":["const ts = Date.now();","const rand = Math.floor(Math.random() * 10000);","pm.collectionVariables.set('uniqueSku', `TEST-${ts}-${rand}`.substring(0, 20));","pm.collectionVariables.set('uniqueEmail', `test-${ts}@example.com`);","pm.collectionVariables.set('nonExistentId', '00000000-0000-0000-0000-000000000000');","pm.collectionVariables.set('uniqueSku2', `TST2-${ts}-${rand}`.substring(0, 20));","pm.collectionVariables.set('uniqueEmail2', `test2-${ts}@example.com`);"],"type":"text/javascript"}}]},{"name":"Setup: Create fixture product","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Fixture Product\",\"sku\":\"{{uniqueSku}}\",\"price\":29.99,\"stock\":100}"},"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Setup: fixture product created with 201', function () {","    pm.response.to.have.status(201);","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('name');","    pm.expect(jsonData).to.have.property('sku');","    pm.expect(jsonData).to.have.property('price');","    pm.expect(jsonData).to.have.property('stock');","    pm.collectionVariables.set('createdProductId', jsonData.id);","    pm.collectionVariables.set('createdProductSku', jsonData.sku);","});"],"type":"text/javascript"}}]}]},{"name":"1. Health","item":[{"name":"GET /health","item":[{"name":"200 - returns ok status","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});"],"type":"text/javascript"}}]},{"name":"200 - response structure is valid","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/health","host":["{{baseUrl}}"],"path":["health"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Response returns valid JSON', function () {","    pm.response.to.be.ok;","    pm.response.to.be.json;","});"],"type":"text/javascript"}}]}]}]},{"name":"2. Products","item":[{"name":"GET /products","item":[{"name":"200 - returns list of products","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response is array', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.be.an('array');","});"],"type":"text/javascript"}}]},{"name":"200 - paginated list respects limit parameter","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products?limit=5&offset=0","host":["{{baseUrl}}"],"path":["products"],"query":[{"key":"limit","value":"5"},{"key":"offset","value":"0"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response is array with max 5 items', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.be.an('array');","    pm.expect(jsonData.length).to.be.at.most(5);","});"],"type":"text/javascript"}}]},{"name":"200 - product items have required fields","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products?limit=1","host":["{{baseUrl}}"],"path":["products"],"query":[{"key":"limit","value":"1"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Product items have required schema fields', function () {","    var jsonData = pm.response.json();","    if (jsonData.length > 0) {","        var product = jsonData[0];","        pm.expect(product).to.have.property('id');","        pm.expect(product).to.have.property('name');","        pm.expect(product).to.have.property('sku');","        pm.expect(product).to.have.property('price');","        pm.expect(product).to.have.property('stock');","        pm.expect(product).to.have.property('created_at');","    }","});"],"type":"text/javascript"}}]}]},{"name":"POST /products","item":[{"name":"201 - creates product with valid data","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Test Product\",\"sku\":\"{{uniqueSku2}}\",\"price\":19.99,\"stock\":50}"},"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 201', function () {","    pm.response.to.have.status(201);","});","pm.test('Response has required product fields', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('name');","    pm.expect(jsonData.name).to.equal('Test Product');","    pm.expect(jsonData).to.have.property('sku');","    pm.expect(jsonData).to.have.property('price');","    pm.expect(jsonData.price).to.equal(19.99);","    pm.expect(jsonData).to.have.property('stock');","    pm.expect(jsonData).to.have.property('created_at');","});"],"type":"text/javascript"}}]},{"name":"401 - missing authorization header","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Test Product\",\"sku\":\"NEWSKU-001\",\"price\":19.99,\"stock\":50}"},"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 401 without auth', function () {","    pm.response.to.have.status(401);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]},{"name":"422 - invalid request body (missing required field)","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Test Product\",\"price\":19.99}"},"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 422 for validation error', function () {","    pm.response.to.have.status(422);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]},{"name":"409 - conflict: SKU already exists","request":{"method":"POST","header":[{"key":"Authorization","value":"Bearer {{authToken}}"},{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"name\":\"Duplicate Product\",\"sku\":\"{{createdProductSku}}\",\"price\":15.99,\"stock\":30}"},"url":{"raw":"{{baseUrl}}/products","host":["{{baseUrl}}"],"path":["products"]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 409 for SKU conflict', function () {","    pm.response.to.have.status(409);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]}]},{"name":"GET /products/{product_id}","item":[{"name":"200 - returns product when exists","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products/{{createdProductId}}","host":["{{baseUrl}}"],"path":["products","{{createdProductId}}"],"variable":[{"key":"product_id","value":"{{createdProductId}}"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 200', function () {","    pm.response.to.have.status(200);","});","pm.test('Response has correct product fields', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('id');","    pm.expect(jsonData).to.have.property('name');","    pm.expect(jsonData).to.have.property('sku');","    pm.expect(jsonData).to.have.property('price');","    pm.expect(jsonData).to.have.property('stock');","    pm.expect(jsonData).to.have.property('created_at');","    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('createdProductId'));","});"],"type":"text/javascript"}}]},{"name":"404 - returns not found when product does not exist","request":{"method":"GET","header":[],"url":{"raw":"{{baseUrl}}/products/{{nonExistentId}}","host":["{{baseUrl}}"],"path":["products","{{nonExistentId}}"],"variable":[{"key":"product_id","value":"{{nonExistentId}}"}]}},"event":[{"listen":"test","script":{"exec":["pm.test('Status is 404 for non-existent product', function () {","    pm.response.to.have.status(404);","});","pm.test('Error response has detail field', function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.have.property('detail');","});"],"type":"text/javascript"}}]}]}]},{"name":"3. Orders","item":[{"name":"POST /orders","item":[{"name":"201 - creates order with