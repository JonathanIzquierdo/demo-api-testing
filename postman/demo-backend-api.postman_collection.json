              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "const rand = Math.floor(Math.random() * 10000);",
                  "const skuRaw = 'TST' + ts + rand;",
                  "const sku = skuRaw.substring(0, 20).toUpperCase();",
                  "pm.collectionVariables.set('uniqueSku', sku);",
                  "pm.collectionVariables.set('uniqueEmail', 'test-' + ts + '-' + rand + '@example.com');",
                  "pm.collectionVariables.set('nonExistentId', '00000000-0000-0000-0000-000000000000');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Setup: unique values generated', function () {",
                  "    pm.expect(pm.collectionVariables.get('uniqueSku')).to.not.be.empty;",
                  "    pm.expect(pm.collectionVariables.get('uniqueEmail')).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
